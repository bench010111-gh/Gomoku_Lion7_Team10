  m_Script: {fileID: 11500000, guid: 6870e667035f39b4a9cbc2c44898579b, type: 3}
  m_Name: DG_Normal_Intro
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: "\uB2E8\uC18C \uC0B4\uC778\uB9C8"
    dialogueText: "\uB108 \uB204\uAD6C\uC57C?"
    speakerPortrait: {fileID: -5611744316132369330, guid: c19e984346a2f86428938b126e436e45, type: 3}
  - speakerName: "\uB2E8\uC18C \uC0B4\uC778\uB9C8"
    dialogueText: "\uB108\uB3C4 \uAE4C\uBD88\uB798?"
    speakerPortrait: {fileID: -5611744316132369330, guid: c19e984346a2f86428938b126e436e45, type: 3}
  - speakerName: "(\uD68C\uC6D0\uB2D8)"
    dialogueText: ...?
    speakerPortrait: {fileID: 617562206183986790, guid: 25cb75c6df166be49a842f459d1106f1, type: 3}
  - speakerName: "\uB2E8\uC18C \uC0B4\uC778\uB9C8"
    dialogueText: "Who are you? \uD655 \uADF8\uB0E5!"
    speakerPortrait: {fileID: -5611744316132369330, guid: c19e984346a2f86428938b126e436e45, type: 3}
  - speakerName: "\uB2E8\uC18C \uC0B4\uC778\uB9C8"
    dialogueText: "\uCF71! \uADF8\uB0E5! \uC548 \uB54C\uB838\uC5B4!"
    speakerPortrait: {fileID: -5611744316132369330, guid: c19e984346a2f86428938b126e436e45, type: 3}
  - speakerName: "(\uD68C\uC6D0\uB2D8)"
    dialogueText: "\uC624\uBAA9.. \uD55C \uD310 \uB9CC.."
    speakerPortrait: {fileID: 617562206183986790, guid: 25cb75c6df166be49a842f459d1106f1, type: 3}
  - speakerName: "\uB2E8\uC18C \uC0B4\uC778\uB9C8"
    dialogueText: "\uC790\uB9AC\uC5D0 \uC549\uC5B4!"
    speakerPortrait: {fileID: -5611744316132369330, guid: c19e984346a2f86428938b126e436e45, type: 3}
  - speakerName: "\uB2E8\uC18C \uC0B4\uC778\uB9C8"
    dialogueText: "\uC624\uBAA9 \uB46C! \uD655 \uADF8\uB0E5!"
    speakerPortrait: {fileID: -5611744316132369330, guid: c19e984346a2f86428938b126e436e45, type: 3}
  - speakerName: "(\uD68C\uC6D0\uB2D8)"
    dialogueText: "(\uC0AC\uB78C\uC740 \uAD1C\uCC2E\uC740 \uAC83 \uAC19\uC740\uB370...
      \uAE30\uBD84 \uD0D3\uC778\uAC00?)"
    speakerPortrait: {fileID: 617562206183986790, guid: 25cb75c6df166be49a842f459d1106f1, type: 3}
