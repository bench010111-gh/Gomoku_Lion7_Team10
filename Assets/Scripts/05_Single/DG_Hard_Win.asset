  m_Script: {fileID: 11500000, guid: 6870e667035f39b4a9cbc2c44898579b, type: 3}
  m_Name: DG_Hard_Win
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: "\uC790\uB974\uBC18 84\uC138"
    dialogueText: "\uB0B4\uAC00 \uC740\uD1F4\uD560 \uB098\uC774\uAC00 \uC628 \uAC83
      \uAC19\uAD70"
    speakerPortrait: {fileID: 3498594231989565091, guid: 85dd5ef09391496459e259f80a31dc3d, type: 3}
  - speakerName: "(\uD68C\uC6D0\uB2D8)"
    dialogueText: "\uC5B4\uB974\uC2E0, \uB108\uBB34 \uC2AC\uD37C\uD558\uC9C0 \uB9C8\uC138\uC694.
      \uC81C\uAC00 \uC9D1\uC73C\uB85C \uBAA8\uC154\uB2E4 \uB4DC\uB9B4\uAE4C\uC694?"
    speakerPortrait: {fileID: 617562206183986790, guid: 25cb75c6df166be49a842f459d1106f1, type: 3}
  - speakerName: "\uC790\uB974\uBC18 84\uC138"
    dialogueText: "\uB410\uB124.. \uB0B4\uAC00 \uC774 \uACF5\uC6D0\uC5D0\uC11C \uB9CC\uB0A0
      \uC0AC\uB78C\uC774 \uC788\uC5B4\uC11C..."
    speakerPortrait: {fileID: 3498594231989565091, guid: 85dd5ef09391496459e259f80a31dc3d, type: 3}
  - speakerName: "\uC790\uB974\uBC18 84\uC138"
    dialogueText: "\uC0AC\uC2E4 \uB0B4 \uC774\uB984\uC740 \uBC15\uC7AC\uBC94 \uC790\uB974\uBC18
      84\uC138\uB77C\uB124.\n\uC774\uC81C \uACE7 \uC9C0\uC778\uC774 \uC624\uB2C8
      \uB09C \uC774\uB9CC \uAC00\uACA0\uB124."
    speakerPortrait: {fileID: 3498594231989565091, guid: 85dd5ef09391496459e259f80a31dc3d, type: 3}
  - speakerName: "(\uD68C\uC6D0\uB2D8)"
    dialogueText: "\uC5B4\uB77C?"
    speakerPortrait: {fileID: 617562206183986790, guid: 25cb75c6df166be49a842f459d1106f1, type: 3}
  - speakerName: "(\uD68C\uC6D0\uB2D8)"
    dialogueText: "\uD0D1\uACE8\uACF5\uC6D0\uC740 \uBB34\uC2A8 \uACF3\uC77C\uAE4C"
    speakerPortrait: {fileID: 617562206183986790, guid: 25cb75c6df166be49a842f459d1106f1, type: 3}
