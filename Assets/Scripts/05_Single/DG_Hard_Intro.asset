  m_Name: DG_Hard_Intro
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: "\uC790\uB974\uBC18 84\uC138"
    dialogueText: "(\uB450\uB465)"
    speakerPortrait: {fileID: -7630566995849790072, guid: faab09662bac914468ac0de4580e4b06, type: 3}
  - speakerName: "\uC790\uB974\uBC18 84\uC138"
    dialogueText: "\uB098\uC5EC, \uC790\uB974\uBC18, 84\uC138."
    speakerPortrait: {fileID: -7630566995849790072, guid: faab09662bac914468ac0de4580e4b06, type: 3}
  - speakerName: "(\uD68C\uC6D0\uB2D8)"
    dialogueText: "\uC5B4\uB974\uC2E0 \uAD1C\uCC2E\uC73C\uC138\uC694?"
    speakerPortrait: {fileID: 617562206183986790, guid: 25cb75c6df166be49a842f459d1106f1, type: 3}
  - speakerName: "\uC790\uB974\uBC18 84\uC138"
    dialogueText: "\uC774 \uC218\uB9CE\uC740 \uD6C8\uC7A5\uB4E4\uC774 \uBCF4\uC774\uC9C0
      \uC54A\uB098?\r\n\uD6C8\uC7A5 \uD558\uB098\uB2F9\u2026 \uB0B4\uAC00 \uBCF4\uB0B8
      \uBAA9\uC228 \uD558\uB098\uB77C\uB124."
    speakerPortrait: {fileID: -7630566995849790072, guid: faab09662bac914468ac0de4580e4b06, type: 3}
  - speakerName: "\uC790\uB974\uBC18 84\uC138"
    dialogueText: "\uC790\uB124\uB3C4\u2026 \uD6C8\uC7A5\uC774 \uB418\uACE0 \uC2F6\uC740
      \uAC90\uAC00?"
    speakerPortrait: {fileID: -7630566995849790072, guid: faab09662bac914468ac0de4580e4b06, type: 3}
  - speakerName: "(\uD68C\uC6D0\uB2D8)"
    dialogueText: "(\uC624\uBAA9 \uCD5C\uC885\uAD00\uBB38\uC778\uAC00?)"
    speakerPortrait: {fileID: 617562206183986790, guid: 25cb75c6df166be49a842f459d1106f1, type: 3}
  - speakerName: "(\uD68C\uC6D0\uB2D8)"
    dialogueText: "\uC88B\uC544\uC694, \uC81C\uAC00 \uD55C \uD310 \uD574\uB4DC\uB9AC\uC8E0"
    speakerPortrait: {fileID: 617562206183986790, guid: 25cb75c6df166be49a842f459d1106f1, type: 3}
